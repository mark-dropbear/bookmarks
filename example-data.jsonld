{
  "@context": "https://schema.org",
  "@type": "DigitalDocument",
  "about": [
    {
      "@type": "ItemList",
      "name": "Bookmark Topics",
      "itemListOrder": "https://schema.org/ItemListUnordered",
      "itemListElement": [
        {
          "@type": "ListItem",
          "item": {
            "@type": "Thing",
            "@id": "topic/123",
            "name": "User title goes here",
            "description": "An optional description goes here",
            "subjectOf": [
              {
                "@id": "webpage/456"
              }
            ]
          }
        }
      ]
    }
  ],
  "mainEntity": {
    "@type": "ItemList",
    "name": "Users bookmarks",
    "itemListOrder": "https://schema.org/ItemListUnordered",
    "itemListElement": [
      {
        "@type": "ListItem",
        "item": {
          "@type": "WebPage",
          "@id": "webpage/456",
          "name": "User title goes here",
          "description": "An optional description goes here",
          "url": "https://www.example.com",
          "about": [
            {
              "@id": "topic/123"
            }
          ]
        }
      }
    ]
  }
}